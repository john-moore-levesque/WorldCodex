# Codex — local dev / deploy configuration
# Copy this file to .env and fill in your values. Never commit .env.

# API Gateway URL (no trailing slash)
VITE_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/Prod

# AWS region where your resources live
VITE_AWS_REGION=us-east-1

# Cognito Identity Pool (for SigV4 credential vending)
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Cognito User Pool (for Google OAuth token exchange)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Hosted UI domain (no https://, no trailing slash)
VITE_COGNITO_DOMAIN=your-app.auth.us-east-1.amazoncognito.com

# Label for the timeline time axis (singular). Defaults to "Year" if unset.
# Worlds with non-calendar time (e.g. a generation ship) can set this to
# "Mission Day", "Cycle", "Tick", etc. Used in form labels and axis legends.
VITE_TIME_UNIT=Year

# Title prefix for the browser tab (rendered as "<title> Codex" in index.html).
# Set per-world, e.g. "My World" → "My World Codex".
VITE_WORLD_TITLE=My World

# ── Deploy targets (used by deploy.sh, not baked into the bundle) ──
DEPLOY_BUCKET=your-s3-bucket-name
# DEPLOY_CLOUDFRONT_ID=EXXXXXXXXXXXX   # optional — omit to skip invalidation
